---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { breadcrumbSchema } from "@/lib/schema";
import { siteConfig } from "@/lib/site";
---

<BaseLayout
  title="Contact | Objectif B2 Espagnol"
  description="Contactez Objectif B2 Espagnol pour poser une question, présenter votre objectif et recevoir une réponse personnalisée."
  pathname="/contact"
  schema={breadcrumbSchema([
    { name: "Accueil", url: "https://www.objectif-b2-espagnol.fr/" },
    { name: "Contact", url: "https://www.objectif-b2-espagnol.fr/contact" }
  ])}
>
  <section class="section-gap">
    <div class="container-shell">
      <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
        <div class="space-y-6">
          <p class="eyebrow">Contact</p>
          <div class="inline-flex items-center gap-3 rounded-full border border-accent/20 bg-white px-4 py-2 text-sm font-bold text-accent shadow-soft">
            <span>Réponse sous 24 à 48h ouvrées</span>
          </div>
          <h1 class="text-5xl lg:text-6xl">Parlons de votre objectif en espagnol</h1>
          <p class="max-w-2xl text-lg leading-8 text-ink/75">
            Décrivez votre situation, votre niveau actuel et votre échéance. Je vous répondrai avec la meilleure orientation possible pour votre préparation.
          </p>
          <div class="surface-card p-8">
            <div class="space-y-4">
              <h2 class="text-3xl">Avant d’écrire</h2>
              <p class="leading-7 text-ink/75">
                Quelques repères utiles pour que votre message soit plus facile à traiter et que je puisse vous répondre de manière pertinente.
              </p>
            </div>
            <ul class="mt-6 space-y-4 leading-7 text-ink/75">
              <li class="flex items-start gap-3">
                <span class="mt-2 h-2.5 w-2.5 rounded-full bg-accent"></span>
                <span>Précisez votre niveau, votre objectif et votre date si vous en avez une.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-2 h-2.5 w-2.5 rounded-full bg-sun"></span>
                <span>Expliquez si vous visez une certification, un échange universitaire ou un besoin plus ponctuel.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-2 h-2.5 w-2.5 rounded-full bg-ink"></span>
                <span>Vous pouvez aussi écrire directement à <a href={`mailto:${siteConfig.email}`} class="font-bold text-accent">{siteConfig.email}</a>.</span>
              </li>
            </ul>
          </div>
          <div class="flex flex-col gap-3 sm:flex-row">
            <a href={`mailto:${siteConfig.email}`} class="btn-primary">
              Écrire par email
            </a>
            <a href={siteConfig.leadMagnetLandingPath} class="btn-secondary">
              Télécharger le guide gratuit
            </a>
          </div>
        </div>

        <div class="surface-card relative overflow-hidden p-8 sm:p-10">
          <div class="absolute inset-x-0 top-0 h-20 bg-gradient-to-r from-accent/10 via-gold/10 to-transparent"></div>
          <div class="relative">
            <p class="eyebrow">Formulaire</p>
            <h2 class="mt-3 text-3xl">Laissez votre message</h2>
            <p class="mt-3 leading-7 text-ink/75">
              Je vous répondrai par email dès que possible.
            </p>

            <form
              action={siteConfig.contactFormAction}
              method="POST"
              class="mt-6 grid gap-4"
            >
            <input type="hidden" name="_subject" value="Nouveau message - page contact" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_next" value={`${siteConfig.siteUrl}${siteConfig.contactThankYouPath}`} />

            <input
              type="text"
              name="name"
              placeholder="Votre prénom"
              class="rounded-2xl border border-line bg-sand px-5 py-3 text-sm outline-none placeholder:text-ink/40 focus:border-accent"
              required
            />

            <input
              type="email"
              name="email"
              placeholder="Votre email"
              class="rounded-2xl border border-line bg-sand px-5 py-3 text-sm outline-none placeholder:text-ink/40 focus:border-accent"
              required
            />

            <textarea
              name="message"
              rows="6"
              placeholder="Expliquez brièvement votre objectif, votre niveau et votre échéance."
              class="rounded-3xl border border-line bg-sand px-5 py-4 text-sm outline-none placeholder:text-ink/40 focus:border-accent"
              required
            ></textarea>

              <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                <button type="submit" class="btn-primary">Envoyer le message</button>
                <a href={`mailto:${siteConfig.email}`} class="btn-secondary">Écrire par email</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
