---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import NewsletterForm from "@/components/NewsletterForm.astro";
import { breadcrumbSchema } from "@/lib/schema";
---

<BaseLayout
  title="Checklist ultime pour reussir le B2 espagnol | Objectif B2 Espagnol"
  description="Page ressource pour telecharger la checklist ultime et structurer une preparation B2/C1 plus clairement."
  pathname="/ressources/guide-b2"
  schema={breadcrumbSchema([
    { name: "Accueil", url: "https://www.objectifb2espagnol.fr/" },
    { name: "Guide B2", url: "https://www.objectifb2espagnol.fr/ressources/guide-b2" }
  ])}
>
  <section class="section-gap">
    <div class="container-shell">
      <Breadcrumbs items={[{ label: "Guide B2", href: "/ressources/guide-b2" }]} />
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div class="space-y-6">
          <p class="eyebrow">Guide gratuit</p>
          <h1 class="text-5xl">Checklist ultime pour reussir le B2 espagnol</h1>
          <p class="max-w-3xl text-lg leading-8 text-ink/75">
            Une ressource simple pour verifier que votre preparation est bien focalisee sur les competences, les criteres et les priorites qui comptent vraiment.
          </p>
          <div class="flex flex-col gap-3 sm:flex-row">
            <a href="#telecharger-guide" class="btn-primary">
              Recevoir le guide par email
            </a>
            <a href="/contact" class="btn-secondary">
              Reserver un diagnostic
            </a>
          </div>
          <ul class="space-y-3 leading-7 text-ink/75">
            <li>Ce qu il faut maitriser avant le jour J.</li>
            <li>Les erreurs les plus frequentes chez les candidats B2.</li>
            <li>Une grille pratique pour savoir si votre plan est assez structure.</li>
          </ul>
        </div>
        <NewsletterForm source="landing-guide-b2" />
      </div>
    </div>
  </section>
</BaseLayout>
