---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NewsletterForm from "@/components/NewsletterForm.astro";
import { breadcrumbSchema } from "@/lib/schema";
---

<BaseLayout
  title="Checklist ultime pour réussir le B2 espagnol | Objectif B2 Espagnol"
  description="Page ressource pour télécharger la checklist ultime et structurer une préparation B2/C1 plus clairement."
  pathname="/ressources/guide-b2"
  schema={breadcrumbSchema([
    { name: "Accueil", url: "https://www.objectif-b2-espagnol.fr/" },
    { name: "Guide B2", url: "https://www.objectif-b2-espagnol.fr/ressources/guide-b2" }
  ])}
>
  <section class="section-gap">
    <div class="container-shell">
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div class="space-y-6">
          <p class="eyebrow">Guide gratuit</p>
          <div class="inline-flex items-center gap-3 rounded-full border border-accent/20 bg-white px-4 py-2 text-sm font-bold text-accent shadow-soft">
            <span>Ressource offerte</span>
          </div>
          <h1 class="text-5xl lg:text-6xl">Checklist ultime pour réussir le B2 espagnol</h1>
          <p class="max-w-3xl text-lg leading-8 text-ink/75">
            Une ressource simple pour vérifier que votre préparation est bien focalisée sur les compétences, les critères et les priorités qui comptent vraiment.
          </p>
          <div class="flex flex-col gap-3 sm:flex-row">
            <a href="#telecharger-guide" class="btn-primary">
              Recevoir le guide par email
            </a>
            <a href="/contact" class="btn-secondary">
              Réserver un diagnostic
            </a>
          </div>
          <ul class="space-y-4 leading-7 text-ink/75">
            <li class="flex items-start gap-3">
              <span class="mt-2 h-2.5 w-2.5 rounded-full bg-accent"></span>
              <span>Ce qu’il faut maîtriser avant le jour J.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-2 h-2.5 w-2.5 rounded-full bg-sun"></span>
              <span>Les erreurs les plus fréquentes chez les candidats B2.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-2 h-2.5 w-2.5 rounded-full bg-ink"></span>
              <span>Une grille pratique pour savoir si votre plan est assez structuré.</span>
            </li>
          </ul>
        </div>
        <NewsletterForm source="landing-guide-b2" />
      </div>
    </div>
  </section>
</BaseLayout>
