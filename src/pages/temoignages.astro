---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import CTAFooter from "@/components/marketing/CTAFooter.astro";
import TestimonialCard from "@/components/marketing/TestimonialCard.astro";
import { breadcrumbSchema } from "@/lib/schema";
import { sortTestimonials } from "@/lib/content";

const testimonials = sortTestimonials(await getCollection("testimonials"));
---

<BaseLayout
  title="Témoignages | Objectif B2 Espagnol"
  description="Retours d’élèves accompagnés vers le niveau B2/C1 avec une méthode claire et structurée."
  pathname="/temoignages"
  schema={breadcrumbSchema([
    { name: "Accueil", url: "https://www.objectif-b2-espagnol.fr/" },
    { name: "Témoignages", url: "https://www.objectif-b2-espagnol.fr/temoignages" }
  ])}
>
  <section class="section-gap">
    <div class="container-shell">
      <div class="space-y-5">
        <p class="eyebrow">Témoignages</p>
        <h1 class="text-5xl lg:text-6xl">Des progrès concrets, une préparation plus sereine</h1>
        <p class="max-w-3xl text-lg leading-8 text-ink/75">
          Les retours ci-dessous illustrent le type d’accompagnement proposé : une méthode claire, un meilleur cadrage et des résultats plus solides à l’examen.
        </p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {testimonials.map((entry) => <TestimonialCard {...entry.data} />)}
      </div>
    </div>
  </section>

  <CTAFooter />
</BaseLayout>
