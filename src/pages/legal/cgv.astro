---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="CGV | Objectif B2 Espagnol"
  description="Conditions generales de vente d Objectif B2 Espagnol."
  pathname="/legal/cgv"
  noindex={true}
>
  <section class="section-gap">
    <div class="container-shell max-w-3xl prose-brand">
      <h1>Conditions generales de vente</h1>
      <p>Version de travail à compléter avant commercialisation. Cette page doit décrire les modalités de réservation, paiement, annulation et responsabilité.</p>
      <p>Le présent starter prépare la route et l’intégration au footer, sans figer un dispositif contractuel incomplet.</p>
    </div>
  </section>
</BaseLayout>
