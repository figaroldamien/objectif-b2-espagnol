  pathname="/legal/cgv"
  noindex={true}
>
  <section class="section-gap">
    <div class="container-shell max-w-3xl prose-brand">
      <h1>Conditions generales de vente</h1>
      <p>Version de travail a completer avant commercialisation. Cette page doit decrire les modalites de reservation, paiement, annulation et responsabilite.</p>
      <p>Le present starter prepare la route et l integration au footer, sans figer un dispositif contractuel incomplet.</p>
    </div>
  </section>
</BaseLayout>
