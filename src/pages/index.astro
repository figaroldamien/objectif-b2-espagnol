---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/marketing/Hero.astro";
import CTAFooter from "@/components/marketing/CTAFooter.astro";
import NewsletterForm from "@/components/NewsletterForm.astro";
import ArticleCard from "@/components/marketing/ArticleCard.astro";
import TestimonialCard from "@/components/marketing/TestimonialCard.astro";
import { organizationSchema, personSchema } from "@/lib/schema";
import { sortBlogPosts, sortTestimonials } from "@/lib/content";

const featuredPosts = sortBlogPosts(
  await getCollection("blog", ({ data }) => !data.draft && data.featured)
).slice(0, 3);

const testimonials = sortTestimonials(
  await getCollection("testimonials", ({ data }) => data.featured)
).slice(0, 3);
---

<BaseLayout
  pathname="/"
  schema={[organizationSchema(), personSchema()]}
>
  <Hero
    title="Une méthode structurée pour atteindre le niveau B2/C1 en espagnol et réussir votre certification."
    description="Un accompagnement clair, rassurant et orienté résultat pour les étudiants qui ont une échéance, veulent un plan précis et ne peuvent plus perdre du temps."
  />

  <section class="section-gap pt-8">
    <div class="container-shell">
      <div class="mb-8 max-w-3xl space-y-3">
        <p class="eyebrow">Pourquoi cette préparation aide vraiment</p>
        <h2 class="text-4xl">Ce que cette préparation change pour vous</h2>
        <p class="text-lg leading-8 text-ink/75">
          L’idée n’est pas de travailler plus. L’idée est d’avancer avec plus de clarté, moins de dispersion et un objectif vraiment maîtrisé.
        </p>
      </div>
      <div class="grid gap-6 lg:grid-cols-3">
        {[
          ["Pour qui", "Vous avez un objectif concret et une date.", "Cette préparation est pensée pour les étudiants et jeunes adultes qui doivent valider un niveau B2/C1 pour partir étudier à l’étranger ou obtenir une certification.", "bg-accent"],
          ["Le vrai problème", "Vous travaillez beaucoup, mais sans savoir quoi prioriser.", "Le manque de méthode fait perdre du temps. Nous clarifions les compétences à travailler, l’ordre de progression et les critères qui comptent à l’examen.", "bg-sun"],
          ["La différence", "Une méthode claire pour réussir votre certification.", "L’approche vient d’un parcours atypique d’ancienne professeure de mathématiques au Chili : beaucoup de structure, peu de flou, des explications faciles à appliquer.", "bg-ink"]
        ].map(([label, title, text, tone]) => (
          <div class="surface-card p-8">
            <span class:list={["mb-5 block h-1.5 w-16 rounded-full", tone]}></span>
            <p class="eyebrow">{label}</p>
            <h2 class="mt-3 text-3xl">{title}</h2>
            <p class="mt-4 leading-7 text-ink/75">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-gap bg-white/50">
    <div class="container-shell">
      <div class="mb-10 max-w-3xl space-y-4">
        <p class="eyebrow">Travail ciblé</p>
        <h2 class="text-4xl">Ce que vous travaillez vraiment pour réussir</h2>
        <p class="text-lg leading-8 text-ink/75">
          L’objectif n’est pas de tout revoir. L’objectif est de travailler ce qui fait réellement progresser un candidat vers le B2/C1.
        </p>
      </div>
      <div class="mx-auto grid max-w-5xl gap-4 sm:grid-cols-2">
        {[
          ["Comprendre les attentes de l’examen", "Vous savez ce qui est vraiment évalué, ce qui compte dans la correction et où concentrer vos efforts."],
          ["Renforcer l’oral et l’écrit utile", "Vous travaillez les formats, les structures et les réflexes qui servent réellement le jour de l’examen."],
          ["Corriger les blocages qui freinent le passage à B2", "On cible les erreurs récurrentes, le manque de précision et les points qui empêchent une expression plus solide."],
          ["Gagner en confiance avec un cadre clair", "Vous avancez avec un plan simple, des priorités nettes et des retours précis pour savoir où vous en êtes."]
        ].map(([title, text]) => (
          <div class="surface-card h-full p-6">
            <h3 class="text-2xl">{title}</h3>
            <p class="mt-3 leading-7 text-ink/75">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-gap">
    <div class="container-shell grid gap-10 lg:grid-cols-[1fr_0.9fr] lg:items-center">
      <div class="space-y-5">
        <p class="eyebrow">Préparation B2/C1</p>
        <h2 class="text-4xl">Programme Objectif B2 en 8 à 12 semaines</h2>
        <p class="max-w-2xl text-lg leading-8 text-ink/75">
          Un accompagnement structuré pour travailler ce qui compte vraiment, avec une progression plus claire et moins de dispersion.
        </p>
        <ul class="space-y-4 leading-7 text-ink/75">
          <li class="flex items-start gap-3">
            <span class="mt-2 h-2.5 w-2.5 rounded-full bg-accent"></span>
            <span>Préparation centrée sur les thèmes qui font vraiment gagner des points.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-2 h-2.5 w-2.5 rounded-full bg-sun"></span>
            <span>Accompagnement adapté à une date d’examen ou un objectif universitaire.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-2 h-2.5 w-2.5 rounded-full bg-ink"></span>
            <span>Approche simple à suivre même si vous manquez de temps.</span>
          </li>
        </ul>
        <a href="/cours/espagnol-certification" class="btn-primary">Découvrir la préparation B2/C1</a>
      </div>
      <NewsletterForm compact={true} />
    </div>
  </section>

  <section class="section-gap">
    <div class="container-shell">
      <div class="mb-8 space-y-3">
        <p class="eyebrow">Témoignages</p>
        <h2 class="text-4xl">Des étudiants qui voulaient un cadre clair et un résultat concret</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {testimonials.map((entry) => <TestimonialCard {...entry.data} />)}
      </div>
    </div>
  </section>

  <section class="section-gap bg-white/40">
    <div class="container-shell">
      <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="space-y-2">
          <p class="eyebrow">Blog</p>
          <h2 class="text-4xl">Des contenus pensés pour attirer, rassurer et convertir</h2>
        </div>
        <a href="/blog" class="btn-secondary">Voir tous les articles</a>
      </div>
      <div class="grid gap-6 lg:grid-cols-3">
        {featuredPosts.map((post) => <ArticleCard post={post} />)}
      </div>
    </div>
  </section>

  <CTAFooter />
</BaseLayout>
