---
type Item = { label: string; href: string };
type Props = { items: Item[] };

const { items } = Astro.props;
---

<nav aria-label="Fil d Ariane" class="mb-8">
  <ol class="flex flex-wrap items-center gap-2 text-sm text-ink/60">
    <li><a href="/" class="hover:text-accent">Accueil</a></li>
    {
      items.map((item) => (
        <>
          <li>/</li>
          <li><a href={item.href} class="hover:text-accent">{item.label}</a></li>
        </>
      ))
    }
  </ol>
</nav>
