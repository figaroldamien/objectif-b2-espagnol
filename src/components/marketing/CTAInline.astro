---
import { primaryCtas } from "@/lib/site";

type Variant = keyof typeof primaryCtas;
type Props = {
  variant?: Variant;
  title?: string;
  description?: string;
};

const {
  variant = "diagnostic",
  title = variant === "guide" ? "Besoin d’un plan clair pour le B2 ?" : "Prêt à structurer votre préparation ?",
  description = variant === "guide"
    ? "Téléchargez le guide gratuit pour savoir quoi travailler avant l’examen."
    : "Réservez un diagnostic pour repartir avec une stratégie adaptée à votre niveau et votre échéance."
} = Astro.props;

const cta = primaryCtas[variant];
---

<aside class="surface-card my-10 p-8">
  <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
    <div class="space-y-2">
      <p class="eyebrow">Passer à l’action</p>
      <h2 class="text-2xl">{title}</h2>
      <p class="max-w-2xl leading-7 text-ink/75">{description}</p>
    </div>
    <a href={cta.href} class="btn-primary">{cta.label}</a>
  </div>
</aside>
