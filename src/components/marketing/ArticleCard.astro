---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "@/lib/content";

type Props = {
  post: CollectionEntry<"blog">;
};

const { post } = Astro.props;
---

<article class="surface-card h-full overflow-hidden">
  <a href={`/blog/${post.slug}`} class="block">
    <div class="space-y-4 p-7">
      <div class="flex flex-wrap items-center gap-3 text-sm text-ink/55">
        <span class="inline-flex rounded-full bg-ink/6 px-3 py-1 font-bold text-ink">{post.data.category}</span>
        <span>•</span>
        <span>{formatDate(post.data.publishDate)}</span>
      </div>
      <div class="space-y-3">
        <h2 class="text-2xl">{post.data.title}</h2>
        <p class="leading-7 text-ink/75">{post.data.excerpt}</p>
      </div>
      <span class="inline-flex items-center gap-2 text-sm font-bold text-accent">
        Lire l’article
        <span aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</article>
