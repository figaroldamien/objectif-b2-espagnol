---
import { siteConfig } from "@/lib/site";

type Props = {
  compact?: boolean;
  title?: string;
  description?: string;
  source?: string;
};

const {
  compact = false,
  title = "Recevez le guide gratuit pour réussir le B2 espagnol",
  description = "Un guide simple pour savoir quoi travailler, dans quel ordre et avec quels critères.",
  source = "site"
} = Astro.props;
---

<div id="telecharger-guide" class:list={["surface-card relative overflow-hidden", compact ? "p-6" : "p-8 sm:p-10"]}>
  <div class="absolute inset-x-0 top-0 h-20 bg-gradient-to-r from-gold/14 via-accent/8 to-transparent"></div>
  <div class="relative space-y-3">
    <p class="eyebrow">Guide gratuit</p>
    <h2 class="text-2xl sm:text-3xl">{title}</h2>
    <p class="max-w-2xl text-base leading-7 text-ink/75">{description}</p>
  </div>

  <form
    action={siteConfig.newsletterFormAction}
    method="POST"
    class="relative mt-6 grid gap-3 sm:grid-cols-[1fr_auto]"
  >
    <input type="hidden" name="_subject" value={`Nouvelle demande de guide B2 - ${source}`} />
    <input
      type="hidden"
      name="_next"
      value={`${siteConfig.siteUrl}${siteConfig.leadMagnetThankYouPath}`}
    />
    <input type="hidden" name="_captcha" value="false" />
    <input type="hidden" name="_template" value="table" />
    <input type="hidden" name="source" value={source} />
    <input
      type="email"
      name="email"
      placeholder="Votre email"
      class="rounded-full border border-line bg-sand px-5 py-3 text-sm outline-none ring-0 placeholder:text-ink/40 focus:border-accent"
      aria-label="Votre email"
      required
    />
    <button type="submit" class="btn-primary">
      Télécharger le guide gratuit
    </button>
  </form>

  {
    !compact && (
      <p class="mt-3 text-xs leading-6 text-ink/55">
        Le formulaire est configuré pour un flux simple compatible site statique. Première étape à faire en production : valider l’adresse sur FormSubmit lors du premier envoi.
      </p>
    )
  }
</div>
